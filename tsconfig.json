{
    "compilerOptions": {
        "target": "es6",
        "allowJs": true,
        "baseUrl": "./",
        "strict": true,
        "removeComments": true,
        "moduleResolution": "node",
        "sourceMap": true,
        "noImplicitAny": true,
        "jsx": "react-jsx",
        "esModuleInterop": true,
        "pretty": true,
        "module": "ES2015",
        "lib": [
            "dom",
            "ES2015",
            "ES2016",
            "ES2017",
            "ES2018",
            "ES2019",
            "ES2020"
        ]
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules"]
}